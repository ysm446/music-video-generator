{
  "1": {
    "class_type": "LoadImage",
    "_meta": {"title": "Load Image"},
    "inputs": {
      "image": "input.png",
      "upload": "image"
    }
  },
  "2": {
    "class_type": "WanVideoModelLoader",
    "_meta": {"title": "WAN2.2 Model Loader"},
    "inputs": {
      "model": "wan2.2_i2v.safetensors",
      "precision": "bf16"
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"},
    "inputs": {
      "text": "",
      "clip": ["2", 1]
    }
  },
  "4": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"},
    "inputs": {
      "text": "",
      "clip": ["2", 1]
    }
  },
  "5": {
    "class_type": "WanVideoSampler",
    "_meta": {"title": "WAN Video Sampler"},
    "inputs": {
      "model": ["2", 0],
      "positive": ["3", 0],
      "negative": ["4", 0],
      "image": ["1", 0],
      "seed": -1,
      "steps": 20,
      "cfg": 6.0,
      "num_frames": 81,
      "frame_rate": 16
    }
  },
  "6": {
    "class_type": "VHS_VideoCombine",
    "_meta": {"title": "Video Combine"},
    "inputs": {
      "images": ["5", 0],
      "frame_rate": 16,
      "loop_count": 0,
      "filename_prefix": "mv_scene",
      "format": "video/h264-mp4",
      "save_output": true
    }
  }
}
